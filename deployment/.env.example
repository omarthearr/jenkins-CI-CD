# Plantilla de variables de entorno para PRODUCCION.
# Copia este archivo a .env en /home/ubuntu/cargasdeployment2025 y rellena los valores reales.
# NUNCA versionar el .env real (con secretos).

DB_NAME=cargas_academicas
DB_USER=cargasuser
DB_USER_ADMIN=root
DB_PASSWORD=CAMBIAR
DB_ROOT_PASSWORD=CAMBIAR
DB_HOST=db
DEBUG=False

# Generar con:  python3 -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=CAMBIAR

# Version de imagen a desplegar. El pipeline la fija automaticamente (vN).
# Para rollback manual, cambiar a una version previa y redeployar.
IMAGE_TAG=latest
